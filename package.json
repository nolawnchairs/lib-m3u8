{
  "name": "@knightinteractive/m3u8",
  "version": "1.3.2",
  "description": "Library for parsing, manipulating and producing ad-hoc m3u8 files for HLS",
  "main": "lib/index.js",
  "author": "Mike <nolawnchairs@gmail.com>",
  "homepage": "https://bitbucket.org/knightinteractive/lib-m3u8",
  "repository": {
    "type": "git",
    "url": "https://bitbucket.org/knightinteractive/lib-m3u8"
  },
  "license": "ISC",
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "test",
    "testRegex": ".*\\.spec\\.[jt]s$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts"
    ],
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@typescript-eslint/eslint-plugin": "^6.7.3",
    "@typescript-eslint/parser": "^6.7.3",
    "eslint": "^8.50.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.1.6"
  },
  "scripts": {
    "test": "jest",
    "clean": "rm -rf ./lib",
    "test-runner": "jest --watchAll",
    "build": "npm run clean && tsc",
    "prepublish": "npm test"
  }
}