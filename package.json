{
  "name": "@nolawnchairs/m3u8",
  "version": "1.5.0",
  "description": "Library for parsing, manipulating and producing ad-hoc m3u8 files for HLS",
  "main": "lib/index.js",
  "author": "Mike <nolawnchairs@gmail.com>",
  "homepage": "https://github.com/nolawnchairs/lib-m3u8",
  "repository": {
    "type": "git",
    "url": "https://github.com/nolawnchairs/lib-m3u8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "test",
    "testRegex": ".*\\.spec\\.[jt]s$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts"
    ],
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@knightinteractive/eslint-plugin": "^1.0.0-alpha1",
    "@types/jest": "^29.0.0",
    "@typescript-eslint/eslint-plugin": "^6.7.3",
    "@typescript-eslint/parser": "^6.7.3",
    "eslint": "^8.50.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.1.6"
  },
  "scripts": {
    "clean": "rm -rf ./lib",
    "build": "npm run clean && tsc",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "prepublish": "npm test"
  }
}
